generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// =============================================
// USER & TEAM
// =============================================

model User {
  id        String   @id @default(cuid()) @map("_id")
  clerkId   String   @unique
  email     String   @unique
  name      String
  avatar    String?
  role      String   @default("USER")
  plan      String   @default("FREE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teamMembers   TeamMember[]
  ownedTeams    Team[]
  contacts      Contact[]
  leads         Lead[]
  assignedDeals Deal[]          @relation("DealAssignee")
  createdDeals  Deal[]          @relation("DealCreator")
  assignedTasks Task[]          @relation("TaskAssignee")
  createdTasks  Task[]          @relation("TaskCreator")
  activities    Activity[]
  invoices      Invoice[]
  aiSessions    AISession[]
  workflows     Workflow[]
  notifications Notification[]
}

model Team {
  id        String   @id @default(cuid()) @map("_id")
  name      String
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner         User         @relation(fields: [ownerId], references: [id])
  members       TeamMember[]
  pipelines     Pipeline[]
  subscriptions Subscription[]
}

model TeamMember {
  id       String   @id @default(cuid()) @map("_id")
  teamId   String
  userId   String
  role     String   @default("USER")
  joinedAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([teamId, userId])
}

// =============================================
// CRM - CONTACTS & LEADS
// =============================================

model Contact {
  id           String   @id @default(cuid()) @map("_id")
  name         String
  email        String?
  phone        String?
  company      String?
  position     String?
  enrichedData Json?
  createdBy    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  creator  User      @relation(fields: [createdBy], references: [id])
  leads    Lead[]
  invoices Invoice[]
}

model Lead {
  id         String   @id @default(cuid()) @map("_id")
  contactId  String
  status     String   @default("NEW")
  score      Float    @default(0)
  source     String?
  assignedTo String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  contact    Contact    @relation(fields: [contactId], references: [id])
  assignee   User?      @relation(fields: [assignedTo], references: [id])
  activities Activity[]
  deals      Deal[]
  tasks      Task[]
}

// =============================================
// ACTIVITIES
// =============================================

model Activity {
  id          String    @id @default(cuid()) @map("_id")
  leadId      String?
  dealId      String?
  type        String
  description String
  performedBy String
  scheduledAt DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  lead      Lead?  @relation(fields: [leadId], references: [id])
  deal      Deal?  @relation(fields: [dealId], references: [id])
  performer User   @relation(fields: [performedBy], references: [id])
}

// =============================================
// TASKS
// =============================================

model Task {
  id          String    @id @default(cuid()) @map("_id")
  title       String
  description String?
  status      String    @default("TODO")
  priority    String    @default("MEDIUM")
  dueDate     DateTime?
  completedAt DateTime?
  leadId      String?
  dealId      String?
  assignedTo  String?
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  lead     Lead? @relation(fields: [leadId], references: [id])
  deal     Deal? @relation(fields: [dealId], references: [id])
  assignee User? @relation("TaskAssignee", fields: [assignedTo], references: [id])
  creator  User  @relation("TaskCreator", fields: [createdBy], references: [id])
}

// =============================================
// DEAL PIPELINE
// =============================================

model Pipeline {
  id     String   @id @default(cuid()) @map("_id")
  name   String
  teamId String
  stages String[]

  team  Team   @relation(fields: [teamId], references: [id])
  deals Deal[]
}

model Deal {
  id                String    @id @default(cuid()) @map("_id")
  title             String
  leadId            String?
  pipelineId        String
  stage             String    @default("DISCOVERY")
  value             Float
  currency          String    @default("USD")
  probability       Float     @default(0)
  expectedCloseDate DateTime?
  assignedTo        String?
  createdBy         String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  lead       Lead?      @relation(fields: [leadId], references: [id])
  pipeline   Pipeline   @relation(fields: [pipelineId], references: [id])
  assignee   User?      @relation("DealAssignee", fields: [assignedTo], references: [id])
  creator    User       @relation("DealCreator", fields: [createdBy], references: [id])
  invoice    Invoice?
  activities Activity[]
  tasks      Task[]
}

// =============================================
// INVOICING & PAYMENTS
// =============================================

model Invoice {
  id         String        @id @default(cuid()) @map("_id")
  dealId     String?       @unique
  contactId  String
  status     String        @default("DRAFT")
  subtotal   Float
  tax        Float         @default(0)
  total      Float
  dueDate    DateTime?
  createdBy  String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  deal     Deal?          @relation(fields: [dealId], references: [id])
  contact  Contact        @relation(fields: [contactId], references: [id])
  creator  User           @relation(fields: [createdBy], references: [id])
  items    InvoiceItem[]
  payments Payment[]
}

model InvoiceItem {
  id          String @id @default(cuid()) @map("_id")
  invoiceId   String
  description String
  quantity    Int
  unitPrice   Float
  amount      Float

  invoice Invoice @relation(fields: [invoiceId], references: [id])
}

model Payment {
  id        String   @id @default(cuid()) @map("_id")
  invoiceId String
  amount    Float
  method    String
  reference String?
  paidAt    DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id])
}

// =============================================
// AI ENGINE
// =============================================

model AISession {
  id        String       @id @default(cuid()) @map("_id")
  userId    String
  title     String?      @default("New Chat")
  context   Json?
  createdAt DateTime     @default(now())
  updatedAt DateTime?    @updatedAt

  user     User         @relation(fields: [userId], references: [id])
  messages AIMessage[]
}

model AIMessage {
  id        String   @id @default(cuid()) @map("_id")
  sessionId String
  role      String
  content   String
  metadata  Json?
  createdAt DateTime @default(now())

  session AISession @relation(fields: [sessionId], references: [id])
}

// =============================================
// SUBSCRIPTION & BILLING
// =============================================

model Subscription {
  id        String    @id @default(cuid()) @map("_id")
  teamId    String
  stripeId  String    @unique
  plan      String    @default("FREE")
  status    String    @default("ACTIVE")
  startDate DateTime
  endDate   DateTime?
  autoRenew Boolean   @default(true)
  createdAt DateTime  @default(now())

  team Team @relation(fields: [teamId], references: [id])
}

// =============================================
// WORKFLOWS
// =============================================

model Workflow {
  id        String           @id @default(cuid()) @map("_id")
  name      String
  trigger   String
  isActive  Boolean          @default(true)
  createdBy String
  createdAt DateTime         @default(now())

  creator User             @relation(fields: [createdBy], references: [id])
  actions WorkflowAction[]
}

model WorkflowAction {
  id         String @id @default(cuid()) @map("_id")
  workflowId String
  type       String
  config     Json
  order      Int

  workflow Workflow @relation(fields: [workflowId], references: [id])
}

// =============================================
// NOTIFICATIONS
// =============================================

model Notification {
  id        String   @id @default(cuid()) @map("_id")
  userId    String
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
